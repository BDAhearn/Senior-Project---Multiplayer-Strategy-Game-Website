@model TicTacToe
@{
    ViewData["Title"] = "Home Page";
    var rows = new[] { "A", "B", "C" };
    var gameWon = !string.IsNullOrEmpty(Model.Winner) ? true : false;
    var winnerBannerText = Model.Winner == "Draw" ? "It's a Tie" : $"{Model.Winner} wins!";
    var playerTurn = $"{Model.Turn}'s Turn";
}

<div class="text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            @if (gameWon)
            {
                <div class="text-center text-black py-3" style="background-color: rgb(39,168,68)"><h1>@winnerBannerText</h1></div>
                <a asp-controller="TicTacToe" asp-action="NewGame" class="text-decoration-none fw-bold">New Game</a>
            }
            else
            {
                <h1>@playerTurn</h1>
            }
            <form asp-controller="TicTacToe" asp-action="Select" method="post">
                @foreach (var y in Enumerable.Range(0, 3))
                {
                    var rowBorder = y < 2 ? "border-bottom border-3 border-dark" : "";

                    <div class="row g-0 justify-content-center text-center @rowBorder">
                        @foreach (var x in Enumerable.Range(1, 3))
                        {
                            var colBorder = x < 3 ? "border-end border-3 border-dark" : "";
                            var cellId = $"{rows[y]}{x}";
                            var cellValue = Model.GetType().GetProperty(cellId)?.GetValue(Model)?.ToString() ?? "";
                            var buttonDisabled = !string.IsNullOrEmpty(cellValue.ToString()) || gameWon ? "disabled" : "";

                            <div class="col-4 @colBorder">
                                <div class="ratio ratio-1x1">
                                    <button type="submit"
                                            name="button"
                                            class="btn btn-outline-dark w-100 h-100 d-flex align-items-center justify-content-center fw-bold @buttonDisabled"
                                            value="@cellId">
                                        <h2>@cellValue</h2>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
                <input type="hidden" name="model" value="@Model" />
            </form>
        </div>
    </div>
</div>
